# Backend Environment Variables Template
# Copy this file to .env inside the backend directory and set the values.

# MongoDB Connection String (Atlas or Local)
MONGO_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>"

# JWT secret key for signing tokens
JWT_SECRET="generate_a_random_secure_long_string_here"

# Server Port
PORT=5000

# Node Environment (development/production)
NODE_ENV=development

# Gemini API Key (Required if using native Google Gemini API fallback or direct connection)
GEMINI_API_KEY="AIzaSy..."

# OpenRouter Configuration (Required if using OpenRouter)
OPENROUTER_API_KEY="sk-or-v1-..."
OPENROUTER_MODEL="google/gemini-2.0-flash"

# Allowed CORS Frontend URL (Used in app.js for security)
FRONTEND_URL="http://localhost:5173"
